# Rithmic API Health Monitor – Configuration
# Copy this file to .env and fill in your values.

# Path to your live scanner's status JSON
RITHMIC_STATUS_FILE=/tmp/rithmic_scanner_status.json

# Where to write health check results
HEALTH_OUTPUT_FILE=/tmp/rithmic_health.json

# Check interval in seconds (default: 300 = 5 minutes)
HEALTH_CHECK_INTERVAL=300

# Your Rithmic account ID (for display only)
RITHMIC_ACCOUNT_ID=

# Comma-separated process names to check via pgrep
# Example: my_scanner,rithmic_bot
RITHMIC_SCANNER_PROCESSES=

# Directory containing scanner log files
SCANNER_LOG_DIR=.

# Path to truth/cross-validation layer state file (optional)
TRUTH_STATE_FILE=/tmp/truth_state.json
